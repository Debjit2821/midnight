# Midnight Credential Vault Environment Variables Example

# Target Network (preprod, devnet, mainnet)
MIDNIGHT_NETWORK=preprod

# Local or Remote Proof Server URL (default Docker port is 8080)
MIDNIGHT_PROVER_URL=http://localhost:8080

# GraphQL Indexer Endpoint for public blockchain ledger query
MIDNIGHT_INDEXER_URL=http://localhost:8081/graphql

# Web Socket endpoint for block subscription events
MIDNIGHT_INDEXER_WS_URL=ws://localhost:8081/graphql

# Node RPC endpoint for transaction submission
MIDNIGHT_NODE_URL=http://localhost:8082

# Deployed Smart Contract Address (Leave empty before deployment)
# E.g., 01e4a30dbf62768d712ce0dbb41b9c97a8e71cb46b9a8fbc8d6f027a08b5e683bc
MIDNIGHT_CONTRACT_ADDRESS=
