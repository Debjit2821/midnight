# Midnight Credential Vault Environment Variables Example

# Target Network (preprod, devnet, mainnet)
MIDNIGHT_NETWORK=preprod

# Local or Remote Proof Server URL (default Docker port is 8080)
MIDNIGHT_PROVER_URL=http://localhost:8080

# GraphQL Indexer Endpoint for public blockchain ledger query
MIDNIGHT_INDEXER_URL=https://indexer.preprod.midnight.network/api/v4/graphql

# Web Socket endpoint for block subscription events
MIDNIGHT_INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v4/graphql

# Node RPC endpoint for transaction submission
MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network

# Deployed Midnight Preprod contract (Bech32m). Replace only after a new
# deployment has been confirmed on an explorer.
MIDNIGHT_CONTRACT_ADDRESS=mn_contract_preprod18drh4lwsxzzkxrq2ljngnwsv6hatgadulk0qy868a8qws6v3vn8q84ppwl

# Issuer account used for the documented Preprod deployment. This value is
# informational; signing always comes from the connected Lace wallet.
MIDNIGHT_ISSUER_ADDRESS=mn_addr_preprod1l8aq3n0mv6g8zpztycw0xznhxg0ux4wpxctrry4dwy36zcprnhzs53a8js
